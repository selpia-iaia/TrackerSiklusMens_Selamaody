<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF7F8">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamaody"
            android:textColor="@color/pink_main"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_circle_white"
            android:elevation="1dp"
            android:src="@drawable/ic_menu"
            app:tint="@color/black"
            android:contentDescription="Menu" />
    </RelativeLayout>

    <!-- Tabs -->
    <LinearLayout
        android:id="@+id/tabHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:id="@+id/tabLogCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tvTabLogCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jumlah Log"
                android:textColor="@color/pink_main"
                android:textStyle="bold" />
            <View
                android:id="@+id/indicatorLogCount"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="8dp"
                android:background="@color/pink_main" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabHealth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tvTabHealth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kesehatan Anda"
                android:textColor="@color/gray" />
            <View
                android:id="@+id/indicatorHealth"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="8dp"
                android:background="@color/stroke" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabHeader">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Container Jumlah Log -->
            <LinearLayout
                android:id="@+id/containerLogCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp"
                android:visibility="visible">

                <!-- Siklus Saya -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:layout_marginTop="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Siklus Saya"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:src="@drawable/ic_next"
                        app:tint="@color/black"
                        android:contentDescription="Next" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="24dp"
                    android:layout_marginTop="16dp">
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_drop" app:tint="@color/pink_main" android:contentDescription="Flow" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="3 Hari" android:textColor="@color/gray" android:textSize="12sp" />
                            </RelativeLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Siklus Khas" android:textColor="@color/black" android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calendar" app:tint="@color/gray" android:contentDescription="Cycle" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="26 Hari" android:textColor="@color/gray" android:textSize="12sp" />
                            </RelativeLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Siklus Khas" android:textColor="@color/black" android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Aliran Darah -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:layout_marginTop="24dp"
                    android:text="Aliran Darah Menstruasi"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingVertical="12dp">
                    <LinearLayout
                        android:id="@+id/flowContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="24dp">
                        <!-- Dinamis via Kotlin -->
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Gejala -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:layout_marginTop="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gejala"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:src="@drawable/ic_next"
                        app:tint="@color/black"
                        android:contentDescription="Next" />
                </RelativeLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingVertical="12dp">
                    <LinearLayout
                        android:id="@+id/symptomsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="24dp">
                        <!-- Dinamis via Kotlin -->
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Mood -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:layout_marginTop="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mood"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:src="@drawable/ic_next"
                        app:tint="@color/black"
                        android:contentDescription="Next" />
                </RelativeLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingVertical="12dp">
                    <LinearLayout
                        android:id="@+id/moodContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="24dp">
                        <!-- Dinamis via Kotlin -->
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Obat -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:layout_marginTop="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Obat"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:src="@drawable/ic_next"
                        app:tint="@color/black"
                        android:contentDescription="Next" />
                </RelativeLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingVertical="12dp">
                    <LinearLayout
                        android:id="@+id/medicineContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="24dp">
                        <!-- Dinamis via Kotlin -->
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:layout_marginTop="24dp"
                    android:text="Catatan"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etStatsNote"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_pill_pink_light"
                    android:gravity="top"
                    android:hint="Tambahkan catatan siklus Anda di sini..."
                    android:padding="16dp"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/gray"
                    android:inputType="textMultiLine"
                    android:autofillHints="none" />

                <Button
                    android:id="@+id/btnSaveNote"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_button_pink"
                    android:text="Simpan Catatan"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/pink_main" />

            </LinearLayout>

            <!-- Container Kesehatan Anda -->
            <LinearLayout
                android:id="@+id/containerHealth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp"
                android:visibility="gone">

                <!-- Weight Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Berat(kg)" android:textColor="@color/black" android:textSize="16sp" android:textStyle="bold" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:orientation="horizontal">
                                <ImageView android:id="@+id/btnWeightBar" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_bar_chart" android:padding="6dp" android:background="@drawable/bg_circle_pink" app:tint="@color/white" android:contentDescription="Bar Chart" />
                                <ImageView android:id="@+id/btnWeightLine" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="8dp" android:src="@drawable/ic_line_chart" android:padding="6dp" android:background="@drawable/bg_circle_white" app:tint="@color/gray" android:contentDescription="Line Chart" />
                            </LinearLayout>
                        </RelativeLayout>

                        <include layout="@layout/layout_chart_navigator" />

                        <com.example.trackersiklusmenstruasi.HealthChartView
                            android:id="@+id/weightChart"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:layout_marginTop="16dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- BMI Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BMI" android:textColor="@color/gray" android:textSize="12sp" android:background="@drawable/bg_pill_white" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:elevation="1dp" />
                            <TextView android:id="@+id/tvBMICategory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Normal" android:textColor="@color/white" android:textSize="12sp" android:background="@drawable/bg_button_pink" android:paddingHorizontal="12dp" android:paddingVertical="4dp" app:backgroundTint="#FF5C7A" />
                        </LinearLayout>

                        <com.example.trackersiklusmenstruasi.BMIGaugeView
                            android:id="@+id/bmiGauge"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:layout_marginTop="16dp" />

                        <!-- BMI Legend -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="16dp">
                            <include layout="@layout/item_bmi_legend" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Water Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Air (ml)" android:textColor="@color/black" android:textSize="16sp" android:textStyle="bold" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:orientation="horizontal">
                                <ImageView android:id="@+id/btnWaterBar" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_bar_chart" android:padding="6dp" android:background="@drawable/bg_circle_pink" app:tint="@color/white" android:contentDescription="Bar Chart" />
                                <ImageView android:id="@+id/btnWaterLine" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="8dp" android:src="@drawable/ic_line_chart" android:padding="6dp" android:background="@drawable/bg_circle_white" app:tint="@color/gray" android:contentDescription="Line Chart" />
                            </LinearLayout>
                        </RelativeLayout>

                        <include layout="@layout/layout_chart_navigator" />

                        <com.example.trackersiklusmenstruasi.HealthChartView
                            android:id="@+id/waterChart"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:layout_marginTop="16dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Temp Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Temperature (°C)" android:textColor="@color/black" android:textSize="16sp" android:textStyle="bold" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:orientation="horizontal">
                                <ImageView android:id="@+id/btnTempBar" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_bar_chart" android:padding="6dp" android:background="@drawable/bg_circle_pink" app:tint="@color/white" android:contentDescription="Bar Chart" />
                                <ImageView android:id="@+id/btnTempLine" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="8dp" android:src="@drawable/ic_line_chart" android:padding="6dp" android:background="@drawable/bg_circle_white" app:tint="@color/gray" android:contentDescription="Line Chart" />
                            </LinearLayout>
                        </RelativeLayout>

                        <include layout="@layout/layout_chart_navigator" />

                        <com.example.trackersiklusmenstruasi.HealthChartView
                            android:id="@+id/tempChart"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:layout_marginTop="16dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
