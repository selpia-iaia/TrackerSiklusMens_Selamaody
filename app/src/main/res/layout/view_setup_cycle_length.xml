<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="24dp">

    <!-- Regular / Irregular Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input_capsule"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/tvRegular"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_button_pink"
            android:gravity="center"
            android:text="Teratur"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvIrregular"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Tidak Teratur"
            android:textColor="@color/black"
            android:textSize="14sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/pickerContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:orientation="horizontal"
        android:gravity="center">

        <NumberPicker
            android:id="@+id/pickerCycleStart"
            android:layout_width="60dp"
            android:layout_height="200dp"
            android:descendantFocusability="blocksDescendants" />

        <TextView
            android:id="@+id/tvSeparator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:text="-"
            android:textColor="@color/pink_main"
            android:textSize="24sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <NumberPicker
            android:id="@+id/pickerCycleEnd"
            android:layout_width="60dp"
            android:layout_height="200dp"
            android:descendantFocusability="blocksDescendants"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Hari"
            android:textColor="@color/pink_main"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
