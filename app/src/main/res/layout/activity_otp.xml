<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/peach_bg">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_back_button"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Back" />

    <View
        android:id="@+id/cardBg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="120dp"
        android:background="@drawable/bg_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toTopOf="@id/keypadLayout"
        app:layout_constraintTop_toTopOf="@id/cardBg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Ketik OTP Anda"
            android:textColor="@color/black"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Masukkan OTP yang dikirimkan ke kontak terdaftar Anda untuk melanjutkan."
            android:textAlignment="center"
            android:textColor="@color/gray"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvOtp1"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/bg_input_capsule"
                android:gravity="center"
                android:text="8"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOtp2"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/bg_input_capsule"
                android:gravity="center"
                android:text="7"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOtp3"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/bg_button_white_outline"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/white"
                android:outlineAmbientShadowColor="@color/pink_main" />

            <TextView
                android:id="@+id/tvOtp4"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/bg_input_capsule"
                android:gravity="center"
                android:text=""
                android:textColor="@color/black"
                android:textSize="24sp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Kirim Ulang Kode"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnVerify"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_button_pink"
            android:text="Verifikasi"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/pink_main" />

    </LinearLayout>

    <GridLayout
        android:id="@+id/keypadLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E9E9E9"
        android:columnCount="3"
        android:padding="1dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn1"
            style="@style/KeypadButton"
            android:text="1" />

        <Button
            android:id="@+id/btn2"
            style="@style/KeypadButton"
            android:text="2" />

        <Button
            android:id="@+id/btn3"
            style="@style/KeypadButton"
            android:text="3" />

        <Button
            android:id="@+id/btn4"
            style="@style/KeypadButton"
            android:text="4" />

        <Button
            android:id="@+id/btn5"
            style="@style/KeypadButton"
            android:text="5" />

        <Button
            android:id="@+id/btn6"
            style="@style/KeypadButton"
            android:text="6" />

        <Button
            android:id="@+id/btn7"
            style="@style/KeypadButton"
            android:text="7" />

        <Button
            android:id="@+id/btn8"
            style="@style/KeypadButton"
            android:text="8" />

        <Button
            android:id="@+id/btn9"
            style="@style/KeypadButton"
            android:text="9" />

        <View
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:background="@android:color/white" />

        <Button
            android:id="@+id/btn0"
            style="@style/KeypadButton"
            android:text="0" />

        <ImageButton
            android:id="@+id/btnBackspace"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:background="@android:color/white"
            android:contentDescription="Backspace"
            android:scaleType="centerInside"
            android:src="@drawable/ic_backspace" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
