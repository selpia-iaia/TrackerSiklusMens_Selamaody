<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
        <View android:layout_width="10dp" android:layout_height="10dp" android:layout_gravity="center_vertical" android:background="@drawable/bg_circle_pink" android:backgroundTint="#4285F4" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Berat Sangat Rendah" android:textSize="12sp" android:textColor="@color/gray" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BMI &lt; 17.0" android:textSize="12sp" android:textColor="@color/black" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
        <View android:layout_width="10dp" android:layout_height="10dp" android:layout_gravity="center_vertical" android:background="@drawable/bg_circle_pink" android:backgroundTint="#00ACC1" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Sangat Kurus" android:textSize="12sp" android:textColor="@color/gray" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BMI 17.0-18.4" android:textSize="12sp" android:textColor="@color/black" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
        <View android:layout_width="10dp" android:layout_height="10dp" android:layout_gravity="center_vertical" android:background="@drawable/bg_circle_pink" android:backgroundTint="#FBC02D" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Normal" android:textSize="12sp" android:textColor="@color/gray" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BMI 18.5-25.0" android:textSize="12sp" android:textColor="@color/black" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
        <View android:layout_width="10dp" android:layout_height="10dp" android:layout_gravity="center_vertical" android:background="@drawable/bg_circle_pink" android:backgroundTint="#388E3C" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Berat Badan Berlebih" android:textSize="12sp" android:textColor="@color/gray" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BMI 25.1-27.0" android:textSize="12sp" android:textColor="@color/black" android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
