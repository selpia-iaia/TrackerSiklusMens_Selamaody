<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hi, Selamat Pagi" android:textColor="@color/gray" android:textSize="13sp" />
            <TextView android:id="@+id/tvWelcome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sela 👋" android:textColor="@color/black" android:textSize="22sp" android:textStyle="bold" />
        </LinearLayout>
        <ImageButton android:id="@+id/btnMenu" android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_back_button" android:src="@drawable/ic_menu" app:tint="@color/black" android:contentDescription="Menu" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/calendarStrip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/header">
        <include layout="@layout/item_calendar_day" />
        <include layout="@layout/item_calendar_day" />
        <include layout="@layout/item_calendar_day" />
        <include layout="@layout/item_calendar_day" />
        <include layout="@layout/item_calendar_day" />
        <include layout="@layout/item_calendar_day" />
        <include layout="@layout/item_calendar_day" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cycleContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="40dp"
        app:layout_constraintTop_toBottomOf="@id/calendarStrip">
        <com.example.trackersiklusmenstruasi.CycleProgressView
            android:id="@+id/cycleProgress"
            android:layout_width="260dp"
            android:layout_height="260dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/cycleProgress"
            app:layout_constraintEnd_toEndOf="@id/cycleProgress"
            app:layout_constraintStart_toStartOf="@id/cycleProgress"
            app:layout_constraintTop_toTopOf="@id/cycleProgress">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ovulasi masuk" android:textColor="@color/black" android:textSize="14sp" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="bottom">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" android:textColor="@color/black" android:textSize="44sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Hari" android:textColor="@color/black" android:textSize="18sp" android:layout_marginBottom="8dp" android:textStyle="bold" />
            </LinearLayout>
            <TextView android:id="@+id/tvDaysLeft" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_capsule_gray" android:paddingHorizontal="16dp" android:paddingVertical="6dp" android:text="Tersisa 10 hari lagi" android:textColor="@color/gray" android:textSize="11sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/actionButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/cycleContainer">
        <LinearLayout android:id="@+id/btnAddPeriod" android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:layout_marginEnd="32dp">
            <FrameLayout android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/bg_circle_pink"><ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:src="@drawable/ic_drop" app:tint="@color/white" /></FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Sunting Siklus" android:textColor="@color/black" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout android:id="@+id/btnAddSymptoms" android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical">
            <FrameLayout android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/bg_circle_white" android:elevation="1dp"><ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:src="@drawable/ic_plus" app:tint="@color/gray" /></FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Tambahkan Gejala" android:textColor="@color/black" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/actionButtons">
        <androidx.cardview.widget.CardView android:id="@+id/cardFeeling" android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1" android:layout_marginEnd="12dp" app:cardCornerRadius="24dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/blue_card" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="16dp" android:text="Bagaimana\nperasaanmu?" android:textColor="@color/black" android:textStyle="bold" android:textSize="13sp" />
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView android:id="@+id/cardGrowth" android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1" app:cardCornerRadius="24dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/pink_card" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="16dp" android:text="Fase pertumbuhan" android:textColor="@color/black" android:textStyle="bold" android:textSize="13sp" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
