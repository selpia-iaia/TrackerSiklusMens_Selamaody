    <!-- Garis Bawah -->
    <item android:top="48dp">
        <shape android:shape="line">
            <stroke
                android:width="1dp"
                android:color="#D0D0D0"
                android:dashWidth="4dp"
                android:dashGap="2dp" />
        </shape>
    </item>
</layer-list>
